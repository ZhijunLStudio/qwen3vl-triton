{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "InCoder-32B": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "InCoder-32B",
      "options": {
        "baseURL": "http://192.168.97.11:8010/v1",
        "apiKey": "EMPTY"
      },
      "models": {
        "InCoder-32B": {
          "name": "InCoder-32B",
          "attachment": true,
          "reasoning": false,
          "tools": true,
          "modalities": { "input": ["text"], "output": ["text"] },
          "limit": { "context": 128000, "output": 65535 }
        }
      }
    }
  },
  "model": "InCoder-32B/InCoder-32B",
  "agent": {
    "build": {
      "model": "InCoder-32B/InCoder-32B",
      "temperature": 0.2,
      "max_steps": 60,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": true,
        "grep": true,
        "glob": true,
        "read": true
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  }
}
